model User {
  id          String                        @id @default(dbgenerated("uuidv7()"))
  username    String                        @unique
  displayName String?  @map("display_name")
  email       String                        @unique
  avatarPath  String?  @map("avatar_path")
  createdAt   DateTime @map("created_at")   @default(now()) 
  updatedAt   DateTime @map("updated_at")   @updatedAt 

  authentication     UserAuthentication?
  sessions           Session[]
  invitationsCreated Invitation[] @relation("invitations_created")
  invitationsRedeemed Invitation[] @relation("invitations_redeemed")

  @@map("users")
}


// TODO:
// move failedAttempts ad lockedUntil to Redis cache
// passwordChagedAt is for invalidating tokens issued before a password change
model UserAuthentication {
  id                String                                @id @default(dbgenerated("uuidv7()"))
  userId            String    @map("user_id")             @unique 
  passwordHash      String    @map("password_hash")
  failedAttempts    Int       @map("failed_attempts")     @default(0) 
  lockedUntil       DateTime? @map("locked_until")
  passwordChangedAt DateTime  @map("password_changed_at") @default(now()) 
  createdAt         DateTime  @map("created_at")          @default(now()) 
  updatedAt         DateTime  @map("updated_at")          @updatedAt 

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_authentication")
}


model Session {
  id         String    @id @default(dbgenerated("uuidv7()"))
  token      String    @unique
  userId     String    @map("user_id")
  lastActive DateTime  @default(now()) @map("last_active")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}


model Invitation {
  id         String    @id @default(dbgenerated("uuidv7()"))
  code       String    @unique
  invitedBy  String    @map("invited_by")
  redeemedBy String?   @map("redeemed_by")
  redeemedAt DateTime? @map("redeemed_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  inviter  User  @relation("invitations_created", fields: [invitedBy], references: [id], onDelete: Cascade)
  redeemer User? @relation("invitations_redeemed", fields: [redeemedBy], references: [id], onDelete: SetNull)

  @@map("invitations")
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}
