model User {
  id         String   @id @default(dbgenerated("uuidv7()"))
  email      String   @unique
  realName   String   @map("real_name")
  avatarPath String?  @map("avatar_path")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  pronouns   String?
  bio        String?
  role       String   @default("user")

  authentication      UserAuthentication?
  sessions            Session[]
  invitationsCreated  Invitation[]        @relation("invitations_created")
  invitationsRedeemed Invitation[]        @relation("invitations_redeemed")
  passwordResetCodes  PasswordResetCode[]
  posts               Post[]
  reactions           Reaction[]
  comments            Comment[]

  @@map("users")
}

// TODO:
// move failedAttempts ad lockedUntil to Redis cache
// passwordChangedAt is for invalidating tokens issued before a password change
model UserAuthentication {
  id                String    @id @default(dbgenerated("uuidv7()"))
  userId            String    @unique @map("user_id")
  passwordHash      String    @map("password_hash")
  failedAttempts    Int       @default(0) @map("failed_attempts")
  lockedUntil       DateTime? @map("locked_until")
  passwordChangedAt DateTime  @default(now()) @map("password_changed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_authentication")
}

model Session {
  id         String   @id @default(dbgenerated("uuidv7()"))
  tokenHash  String   @unique @map("token_hash")
  userId     String   @map("user_id")
  lastActive DateTime @default(now()) @map("last_active")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Invitation {
  id         String    @id @default(dbgenerated("uuidv7()"))
  code       String    @unique
  invitedBy  String    @map("invited_by")
  realName   String    @map("real_name")
  redeemedBy String?   @map("redeemed_by")
  redeemedAt DateTime? @map("redeemed_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  inviter  User  @relation("invitations_created", fields: [invitedBy], references: [id], onDelete: Cascade)
  redeemer User? @relation("invitations_redeemed", fields: [redeemedBy], references: [id], onDelete: SetNull)

  @@map("invitations")
}

model PasswordResetCode {
  id        String    @id @default(dbgenerated("uuidv7()"))
  code      String    @unique
  userId    String    @map("user_id")
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_codes")
}

model Post {
  id        String   @id @default(dbgenerated("uuidv7()"))
  authorId  String   @map("author_id")
  caption   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images    PostImage[]
  reactions Reaction[]
  comments  Comment[]

  @@map("posts")
}

model PostImage {
  id            String   @id @default(dbgenerated("uuidv7()"))
  postId        String   @map("post_id")
  imagePath     String   @map("image_path")
  thumbnailPath String   @map("thumbnail_path")
  width         Int?
  height        Int?
  position      Int      @default(0) @db.SmallInt
  createdAt     DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("post_images")
}

model Comment {
  id        String   @id @default(dbgenerated("uuidv7()"))
  postId    String   @map("post_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Reaction {
  id        String   @id @default(dbgenerated("uuidv7()"))
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  kind      Emotion
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("reactions")
}

enum Emotion {
  admiration
  adoration
  aestheticAppreciation    @map("aesthetic_appreciation")
  amusement
  anger
  anxiety
  awe
  awkwardness
  boredom
  calmness
  confusion
  craving
  disgust
  empathicPain             @map("empathic_pain")
  entrancement
  excitement
  fear
  horror
  interest
  joy
  nostalgia
  relief
  romance
  sadness
  satisfaction
  sexualDesire             @map("sexual_desire")
  surprise

  @@map("emotion")
}

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}
