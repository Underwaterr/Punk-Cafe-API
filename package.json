{
  "type": "module",
  "scripts": {
    "start": "node index.ts",
    "dev": "node --watch index.ts",
    "test": "node --env-file=.env.test --test --test-concurrency=1 '**/test.ts'",
    "test:watch": "node --env-file=.env.test --watch --test --test-concurrency=1 '**/test.ts'",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:reset": "docker compose down -v",
    "db:migrate": "prisma migrate dev",
    "db:test:create": "docker exec punk-cafe-db createdb -U punk_cafe_admin punk_cafe_test",
    "db:test:migrate": "DATABASE_URL=postgresql://punk_cafe_admin:password@localhost:5432/punk_cafe_test npx prisma migrate deploy"
  },
  "imports": {
    "#prisma": "./server/database.ts",
    "#test": "./test-utilities.ts",
    "#validator": "./server/validator.ts",
    "#server/*": "./server/*"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vinejs/vine": "^4.3.0",
    "argon2": "^0.44.0",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/sharp": "^0.31.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.5.0"
  }
}
